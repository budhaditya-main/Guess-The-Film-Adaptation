const POINTS_STREAK = 25;
const TOTAL_ROUNDS = 10;

let shuffled = [];
let current = 0;
let score = 0;
let streak = 0;
let answered = false;
let timerInterval = null;
let timerLeft = TIMER_SECONDS;
let idleTimer = null;
let idleActive = false;

function resetIdleTimer() {
  if (idleActive) hideIdle();
  clearTimeout(idleTimer);
  idleTimer = setTimeout(showIdle, 30000);
}

function showIdle() {
  idleActive = true;
  document.getElementById('idle-overlay').style.display = 'block';
  document.getElementById('idle-container').style.display = 'flex';
  document.getElementById('idle-container').style.justifyContent = 'center';
  document.getElementById('idle-container').style.alignItems = 'center';
  document.addEventListener('mousemove', onActivity);
  document.addEventListener('keydown', onActivity);
  document.addEventListener('click', onActivity);
}

function hideIdle() {
  idleActive = false;
  document.getElementById('idle-overlay').style.display = 'none';
  document.getElementById('idle-container').style.display = 'none';
}

function onActivity() {
  hideIdle();
  document.removeEventListener('mousemove', onActivity);
  document.removeEventListener('keydown', onActivity);
  document.removeEventListener('click', onActivity);
  resetIdleTimer();
}

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function selectRandomRounds(data, count) {
  const shuffled = shuffle(data);
  return shuffled.slice(0, count);
}

function startGame() {
  document.getElementById('intro').style.display = 'none';
  document.getElementById('game').style.display = 'block';
  document.getElementById('results').style.display = 'none';
  shuffled = selectRandomRounds(GAME_DATA, TOTAL_ROUNDS);
  current = 0;
  score = 0;
  streak = 0;
  updateTopBar();
  loadRound();
  resetIdleTimer();
}

function goMenu() {
  clearTimeout(idleTimer);
  hideIdle();
  document.getElementById('intro').style.display = 'flex';
  document.getElementById('game').style.display = 'none';
  document.getElementById('results').style.display = 'none';
}

function loadRound() {
  answered = false;
  const item = shuffled[current];

  const img = document.getElementById('scene-img');
  img.classList.remove('loaded');
  img.src = IMAGE_MAP[item.img] || item.img;
  img.onload = function() {
    img.classList.add('loaded');
  };

  document.getElementById('round-chip').textContent = 'Round ' + (current + 1);
  document.getElementById('hint-text').textContent = item.hint;
  document.getElementById('prog-bar').style.width = (current / shuffled.length * 100) + '%';

  const grid = document.getElementById('options-grid');
  grid.innerHTML = '';
  const opts = shuffle(item.options);
  opts.forEach(function(opt) {
    const btn = document.createElement('button');
    btn.className = 'opt-btn';
    btn.textContent = opt;
    btn.onclick = function() {
      handleAnswer(opt, item.title, btn);
    };
    grid.appendChild(btn);
  });

  const fb = document.getElementById('feedback-bar');
  fb.className = 'feedback-bar';
  fb.textContent = '';

  const nb = document.getElementById('next-btn');
  nb.className = 'next-btn';

  startTimer();
  updateTopBar();
}

function startTimer() {
  clearInterval(timerInterval);
  timerLeft = TIMER_SECONDS;
  updateTimerUI();
  timerInterval = setInterval(function() {
    timerLeft--;
    updateTimerUI();
    if (timerLeft <= 0) {
      clearInterval(timerInterval);
      if (!answered) timeOut();
    }
  }, 1000);
}

function updateTimerUI() {
  document.getElementById('timer-fill').style.width = (timerLeft / TIMER_SECONDS * 100) + '%';
  document.getElementById('timer-num').textContent = timerLeft;
}

function handleAnswer(chosen, correct, btn) {
  if (answered) return;
  answered = true;
  clearInterval(timerInterval);
  resetIdleTimer();

  const isCorrect = chosen === correct;
  const btns = document.querySelectorAll('.opt-btn');
  btns.forEach(function(b) {
    b.classList.add('disabled');
    if (b.textContent === correct) b.classList.add('correct');
    else if (b === btn && !isCorrect) b.classList.add('wrong');
  });

  const fb = document.getElementById('feedback-bar');
  if (isCorrect) {
    streak++;
    const pts = POINTS_BASE + (streak > 1 ? POINTS_STREAK * (streak - 1) : 0);
    const bonus = streak > 1 ? ' +' + POINTS_STREAK * (streak - 1) + ' streak!' : '';
    score += pts;
    fb.className = 'feedback-bar correct show';
    fb.textContent = 'Correct! +' + pts + ' pts' + bonus;
  } else {
    streak = 0;
    fb.className = 'feedback-bar wrong show';
    fb.textContent = 'It was "' + correct + '"';
  }

  document.getElementById('next-btn').className = 'next-btn show';
  updateTopBar();
}

function timeOut() {
  answered = true;
  streak = 0;
  const item = shuffled[current];
  const btns = document.querySelectorAll('.opt-btn');
  btns.forEach(function(b) {
    b.classList.add('disabled');
    if (b.textContent === item.title) b.classList.add('correct');
  });
  const fb = document.getElementById('feedback-bar');
  fb.className = 'feedback-bar wrong show';
  fb.textContent = 'Time\'s up! It was "' + item.title + '"';
  document.getElementById('next-btn').className = 'next-btn show';
  updateTopBar();
}

function nextRound() {
  current++;
  if (current >= shuffled.length) {
    showResults();
  } else {
    loadRound();
  }
}

function updateTopBar() {
  document.getElementById('round-disp').textContent = (current + 1) + ' / ' + shuffled.length;
  document.getElementById('score-disp').textContent = score;
  document.getElementById('streak-disp').textContent = streak > 1 ? streak + 'x' : streak;
}

function showResults() {
  clearTimeout(idleTimer);
  document.getElementById('game').style.display = 'none';
  const res = document.getElementById('results');
  res.style.display = 'flex';

  const maxPossible = TOTAL_ROUNDS * POINTS_BASE + ((TOTAL_ROUNDS - 1) * TOTAL_ROUNDS / 2) * POINTS_STREAK;
  const pct = score / maxPossible;

  let crown, title, sub, tagline;
  if (pct >= 0.85) {
    crown = '🏆';
    title = 'Literary Legend';
    sub = 'You matched every adaptation with precision. Truly a reader of the highest caliber.';
    tagline = 'You deserve a place on the shelf.';
  } else if (pct >= 0.65) {
    crown = '📚';
    title = 'Well-Read Soul';
    sub = 'You clearly love both films and books. Your taste is impeccable.';
    tagline = 'A true cinephile and reader.';
  } else if (pct >= 0.4) {
    crown = '📖';
    title = 'Page Turner';
    sub = 'You know your way around a story. Keep exploring the shelves.';
    tagline = 'Your reading list awaits.';
  } else {
    crown = '✨';
    title = 'Story Seeker';
    sub = 'A great start! The wonderful thing about books is they are always waiting for you.';
    tagline = 'Happy reading ahead.';
  }

  document.getElementById('result-crown').textContent = crown;
  document.getElementById('result-title').textContent = title;
  document.getElementById('result-score').textContent = score + ' pts';
  document.getElementById('result-sub').textContent = sub;
  document.getElementById('result-tagline').textContent = tagline;
}

function restartGame() {
  document.getElementById('results').style.display = 'none';
  shuffled = selectRandomRounds(GAME_DATA, TOTAL_ROUNDS);
  current = 0;
  score = 0;
  streak = 0;
  document.getElementById('game').style.display = 'block';
  updateTopBar();
  loadRound();
  resetIdleTimer();
}
</script>
</body>
</html>
