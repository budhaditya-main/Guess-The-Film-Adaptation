<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shared Shelf</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@600;700;800&family=Merriweather:wght@700;900&display=swap');

  *{margin:0;padding:0;box-sizing:border-box;}

  body{
    background:#f5ede3;
    color:#3d3d3d;
    font-family:'Fredoka',sans-serif;
    min-height:100vh;
    overflow-x:hidden;
  }

  /* ===== INTRO SCREEN ===== */
  #intro{
    position:fixed;inset:0;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    background:#f5ede3;
    z-index:100;
    gap:3.5rem;
    text-align:center;
    padding:2rem;
  }

  .intro-badge{
    font-size:28px;letter-spacing:2.5px;text-transform:uppercase;
    color:#d97f6f;font-weight:800;
    opacity: 0;
    animation: fadeInDown 0.6s ease-out forwards;
  }
  
  .intro-title{
    font-family:'Merriweather',serif;
    font-size:clamp(4rem,12vw,8rem);
    line-height:1;
    color:#5a4a3a;
    font-weight:900;
    letter-spacing:-2px;
  }
  
  .cinematic-main-title {
    font-family: 'Merriweather', serif;
    font-size: clamp(2.5rem, 12vw, 6.5rem);
    font-weight: 900;
    color: #5a4a3a;
    line-height: 1.1;
    text-align: center;
    letter-spacing: -2px;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2em;
  }

  .title-word-line {
    opacity: 0;
    animation: wordScaleIn 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .title-word-line:nth-child(1) { animation-delay: 0.3s; }
  .title-word-line:nth-child(2) { animation-delay: 1s; }
  .title-word-line:nth-child(3) { animation-delay: 1.7s; }
  .title-word-line:nth-child(4) { animation-delay: 2.4s; }

  @keyframes wordScaleIn {
    from {
      opacity: 0;
      transform: scaleY(0) scaleX(0.8);
      transform-origin: center;
    }
    to {
      opacity: 1;
      transform: scaleY(1) scaleX(1);
    }
  }

  .title-char {
    opacity: 0;
    display: inline;
    animation: charSlideIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .title-space {
    display: inline;
    width: auto;
  }

  @keyframes charSlideIn {
    from {
      opacity: 0;
      transform: scaleX(0) skewX(10deg);
    }
    to {
      opacity: 1;
      transform: scaleX(1) skewX(0);
    }
  }

  .made-by {
    font-family: 'Fredoka', sans-serif;
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9a8a7a;
    font-weight: 600;
    text-align: center;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
    animation-delay: 3.3s;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .intro-sub{
    font-size:20px;color:#7a6a5a;font-weight:500;max-width:550px;line-height:1.9;
  }
  
  .intro-btn{
    background:#d97f6f;
    color:#fff;
    border:none;padding:20px 56px;border-radius:40px;
    font-family:'Fredoka',sans-serif;font-size:18px;font-weight:800;
    cursor:pointer;transition:all .3s;
    box-shadow: 0 6px 20px rgba(217, 127, 111, 0.25);
    letter-spacing:0.5px;
  }
  
  .intro-btn:hover{
    background:#c96856;
    transform:translateY(-3px);
    box-shadow: 0 10px 30px rgba(217, 127, 111, 0.35);
  }
  
  .animated-btn {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
    animation-delay: 3.8s;
  }
  
  .intro-rounds{font-size:13px;color:#9a8a7a;letter-spacing:1px;margin-top:1rem;}

  /* ===== BLUR / IDLE OVERLAY ===== */
  #idle-overlay{
    position:fixed;inset:0;
    background:#f5ede3;
    z-index:200;
    display:none;
    pointer-events:none;
  }

  #idle-container {
    position: fixed;
    inset: 0;
    z-index: 201;
    pointer-events: none;
    display: none;
    width: 100%;
    height: 100%;
  }

  .idle-char {
    position: absolute;
    font-family: 'Merriweather', serif;
    font-size: 200px;
    font-weight: 900;
    letter-spacing: -15px;
  }

  .idle-char:nth-child(1) { color: #d97f6f; animation: bounce-large 1.2s ease-in-out infinite; }
  .idle-char:nth-child(2) { color: #c96b5a; animation: bounce-large 1.2s ease-in-out infinite 0.1s; }
  .idle-char:nth-child(3) { color: #d97f6f; animation: bounce-large 1.2s ease-in-out infinite 0.2s; }
  .idle-char:nth-child(4) { color: #c96b5a; animation: bounce-large 1.2s ease-in-out infinite 0.3s; }
  .idle-char:nth-child(5) { color: #d97f6f; animation: bounce-large 1.2s ease-in-out infinite 0.4s; }
  .idle-char:nth-child(6) { color: #c96b5a; animation: bounce-large 1.2s ease-in-out infinite 0.5s; }
  .idle-char:nth-child(7) { animation: none; }
  .idle-char:nth-child(8) { color: #d97f6f; animation: bounce-large 1.2s ease-in-out infinite 0.6s; }
  .idle-char:nth-child(9) { color: #c96b5a; animation: bounce-large 1.2s ease-in-out infinite 0.7s; }
  .idle-char:nth-child(10) { color: #d97f6f; animation: bounce-large 1.2s ease-in-out infinite 0.8s; }
  .idle-char:nth-child(11) { color: #c96b5a; animation: bounce-large 1.2s ease-in-out infinite 0.9s; }
  .idle-char:nth-child(12) { color: #d97f6f; animation: bounce-large 1.2s ease-in-out infinite 1s; }

  #idle-text {
    font-family: 'Merriweather', serif;
    font-size: clamp(4rem, 15vw, 10rem);
    font-weight: 900;
    color: #d97f6f;
    letter-spacing: -2px;
    animation: idle-float 3s ease-in-out infinite;
    text-align: center;
  }

  @keyframes idle-float {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(-30px); opacity: 0.9; }
  }

  /* ===== MAIN GAME ===== */
  #game{
    display:none;
    min-height:100vh;
    padding:0;
    background:#f5ede3;
  }

  /* top bar */
  .topbar{
    display:flex;align-items:center;justify-content:space-between;
    padding:28px 50px;
    border-bottom:3px solid #e8ddd0;
    background:#faf6f1;
  }

  .topbar-left{
    display:flex;align-items:center;gap:28px;
  }

  .menu-btn{
    background:transparent;
    border:3px solid #d97f6f;
    color:#d97f6f;
    padding:10px 22px;
    border-radius:30px;
    font-family:'Fredoka',sans-serif;
    font-size:13px;
    font-weight:800;
    cursor:pointer;
    transition:all .3s;
    letter-spacing:0.5px;
  }

  .menu-btn:hover{
    background:#d97f6f;
    color:#fff;
    transform:translateY(-2px);
  }

  .topbar-brand{
    font-family:'Merriweather',serif;
    font-size:28px;color:#5a4a3a;font-weight:900;
  }

  .topbar-meta{display:flex;gap:60px;align-items:center;}
  .meta-item{display:flex;flex-direction:column;align-items:center;gap:4px;}
  .meta-label{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:#9a8a7a;font-weight:800;}
  .meta-val{font-size:28px;font-weight:900;color:#d97f6f;}

  /* progress bar */
  .progress-bar-wrap{
    height:5px;
    background:#e8ddd0;
  }
  
  .progress-bar-fill{
    height:5px;
    background:#d97f6f;
    transition:width .6s ease;
  }

  /* round layout */
  .round-layout{
    display:grid;grid-template-columns:1fr 1fr;
    min-height:calc(100vh - 100px);
  }

  /* image panel */
  .img-panel{
    position:relative;overflow:hidden;
    background:#e8ddd0;
  }

  .img-panel img{
    width:100%;height:100%;
    object-fit:cover;
    display:block;
    opacity:0;
    transition:opacity .6s ease;
  }
  
  .img-panel img.loaded{opacity:1;}

  .round-chip{
    position:absolute;top:28px;left:28px;
    background:#d97f6f;
    color:#fff;
    padding:12px 22px;border-radius:30px;
    font-size:12px;letter-spacing:1.5px;text-transform:uppercase;
    font-weight:800;
    z-index:2;
    box-shadow: 0 4px 15px rgba(217, 127, 111, 0.3);
  }

  /* quiz panel */
  .quiz-panel{
    display:flex;flex-direction:column;justify-content:center;
    padding:60px 60px;
    gap:2.5rem;
    background:#faf6f1;
  }

  .q-label{
    font-size:12px;letter-spacing:2.5px;text-transform:uppercase;
    color:#d97f6f;font-weight:900;
  }

  .q-text{
    font-family:'Merriweather',serif;
    font-size:clamp(1.8rem,2.5vw,2.4rem);
    line-height:1.4;
    color:#5a4a3a;
    font-weight:900;
  }

  .hint-wrap{
    display:flex;align-items:flex-start;gap:12px;
    font-size:15px;color:#7a6a5a;
    border-left:4px solid #d97f6f;
    padding-left:16px;
    background:#f0e8df;
    padding:14px 16px;
    border-radius:10px;
    font-weight:500;
  }

  /* options grid */
  .options-grid{
    display:grid;grid-template-columns:1fr 1fr;
    gap:14px;
  }

  .opt-btn{
    background:#fff;
    border:3px solid #e8ddd0;
    color:#5a4a3a;
    padding:20px 18px;
    text-align:left;
    font-family:'Fredoka',sans-serif;font-size:15px;font-weight:700;
    cursor:pointer;border-radius:14px;
    transition:all .25s;
    line-height:1.5;
  }

  .opt-btn:hover:not(.disabled){
    border-color:#d97f6f;
    box-shadow:0 4px 12px rgba(217, 127, 111, 0.1);
    transform:translateY(-2px);
  }

  .opt-btn.disabled{cursor:not-allowed;opacity:0.6;}
  .opt-btn.correct{background:#d4e5d9;border-color:#6ba876;color:#3d5a45;}
  .opt-btn.wrong{background:#f5ddd9;border-color:#d97f6f;color:#5a4a3a;}

  /* timer */
  .timer-wrap{
    position:relative;
    width:80px;height:80px;
    display:flex;align-items:center;justify-content:center;
  }

  .timer-bg{
    position:absolute;inset:0;
    background:#e8ddd0;border-radius:50%;
  }

  .timer-fill{
    position:absolute;inset:0;
    background:linear-gradient(to right,#d97f6f,#c96b5a);
    border-radius:50%;
    clip-path:polygon(50% 50%,50% 0%,100% 0%,100% 100%,0% 100%,0% 0%);
    transition:clip-path .3s;
  }

  .timer-num{
    position:relative;z-index:2;
    font-family:'Merriweather',serif;
    font-size:32px;font-weight:900;
    color:#5a4a3a;
  }

  /* feedback bar */
  .feedback-bar{
    height:0;overflow:hidden;opacity:0;
    background:#f0e8df;padding:0 20px;
    border-radius:10px;
    font-weight:600;color:#5a4a3a;
    transition:all .4s;
  }

  .feedback-bar.correct{background:#d4e5d9;color:#3d5a45;border:2px solid #6ba876;}
  .feedback-bar.wrong{background:#f5ddd9;color:#5a4a3a;border:2px solid #d97f6f;}

  .feedback-bar.show{
    height:60px;opacity:1;padding:18px 20px;
  }

  /* next btn */
  .next-btn{
    background:#d97f6f;
    color:#fff;
    border:none;padding:18px 40px;
    border-radius:12px;
    font-family:'Fredoka',sans-serif;
    font-size:15px;font-weight:800;
    cursor:pointer;
    transition:all .3s;
    align-self:flex-start;
    opacity:0;pointer-events:none;
  }

  .next-btn:hover{
    background:#c96856;
    transform:translateY(-2px);
  }

  .next-btn.show{opacity:1;pointer-events:all;}

  /* ===== RESULTS SCREEN ===== */
  #results{
    position:fixed;inset:0;
    display:none;flex-direction:column;align-items:center;justify-content:center;
    background:linear-gradient(135deg,#faf6f1 0%,#f5ede3 100%);
    z-index:100;
    gap:2rem;
    padding:3rem;
    text-align:center;
  }

  .result-crown{
    font-family:'Merriweather',serif;
    font-size:72px;
    line-height:1;
    color:#d97f6f;
  }

  .result-title{
    font-family:'Merriweather',serif;
    font-size:clamp(2rem,5vw,3.5rem);
    color:#5a4a3a;
    font-weight:900;
    margin:1rem 0;
  }

  .result-score{
    font-size:56px;
    color:#d97f6f;
    font-weight:900;
    font-family:'Fredoka',sans-serif;
  }

  .result-sub{
    font-size:18px;
    color:#7a6a5a;
    max-width:500px;
    line-height:1.6;
    font-weight:500;
  }

  .result-tagline{
    font-family:'Merriweather',serif;
    font-size:22px;
    color:#d97f6f;
    font-style:italic;
    font-weight:700;
    margin-top:1.5rem;
  }

  .results-btn-group{
    display:flex;gap:20px;margin-top:2rem;
  }

  .results-btn{
    background:#d97f6f;
    color:#fff;
    border:none;
    padding:16px 40px;
    border-radius:40px;
    font-family:'Fredoka',sans-serif;
    font-size:15px;
    font-weight:800;
    cursor:pointer;
    transition:all .3s;
  }

  .results-btn:hover{
    background:#c96856;
    transform:translateY(-2px);
  }

  .results-btn.outline{
    background:transparent;
    border:3px solid #d97f6f;
    color:#d97f6f;
  }

  .results-btn.outline:hover{
    background:#d97f6f;
    color:#fff;
  }

  /* responsive */
  @media (max-width:1024px){
    .round-layout{grid-template-columns:1fr;}
    .quiz-panel{padding:40px;}
  }

  @media (max-width:640px){
    .topbar{padding:20px;}
    .quiz-panel{padding:30px 20px;}
    .options-grid{grid-template-columns:1fr;}
  }
</style>
</head>
<body>

<!-- INTRO SCREEN -->
<div id="intro">
  <div class="cinematic-main-title">
    <div class="title-word-line">MATCH</div>
    <div class="title-word-line">BOOKS</div>
    <div class="title-word-line">TO</div>
    <div class="title-word-line">ADAPTATIONS</div>
  </div>
  <button class="intro-btn animated-btn" onclick="startGame()">Play Now</button>
  <div class="made-by">Made by Shared Shelf Team</div>
</div>

<!-- IDLE OVERLAY -->
<div id="idle-overlay"></div>
<div id="idle-container">
  <div id="idle-text">Shared Shelf</div>
</div>

<!-- GAME SCREEN -->
<div id="game">
  <!-- Top bar -->
  <div class="topbar">
    <div class="topbar-left">
      <button class="menu-btn" onclick="goMenu()">Menu</button>
      <div class="topbar-brand">Shared Shelf</div>
    </div>
    <div class="topbar-meta">
      <div class="meta-item">
        <div class="meta-label">Round</div>
        <div class="meta-val" id="round-disp">1 / 10</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Score</div>
        <div class="meta-val" id="score-disp">0</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Streak</div>
        <div class="meta-val" id="streak-disp">0</div>
      </div>
      <div class="timer-wrap">
        <div class="timer-bg"></div>
        <div class="timer-fill" id="timer-fill"></div>
        <div class="timer-num" id="timer-num">15</div>
      </div>
    </div>
  </div>

  <!-- Progress bar -->
  <div class="progress-bar-wrap">
    <div class="progress-bar-fill" id="prog-bar"></div>
  </div>

  <!-- Main layout -->
  <div class="round-layout">
    <!-- Image panel -->
    <div class="img-panel">
      <img id="scene-img" src="" alt="Scene">
      <div class="round-chip" id="round-chip">Round 1</div>
    </div>

    <!-- Quiz panel -->
    <div class="quiz-panel">
      <div class="q-label">Which book does this film adapt?</div>
      <h2 class="q-text" id="question">Loading...</h2>
      <div class="hint-wrap">
        <span>💡</span>
        <span id="hint-text">Hint text will appear here</span>
      </div>
      <div class="options-grid" id="options-grid"></div>
      <div class="feedback-bar" id="feedback-bar"></div>
      <button class="next-btn" id="next-btn" onclick="nextRound()">Next Round →</button>
    </div>
  </div>
</div>

<!-- RESULTS SCREEN -->
<div id="results">
  <div class="result-crown" id="result-crown">🏆</div>
  <h1 class="result-title" id="result-title">Legendary Reader</h1>
  <div class="result-score" id="result-score">950 pts</div>
  <p class="result-sub" id="result-sub">You perfectly matched every adaptation!</p>
  <div class="result-tagline" id="result-tagline">"A reader after all!"</div>
  <div class="results-btn-group">
    <button class="results-btn" onclick="restartGame()">Play Again</button>
    <button class="results-btn outline" onclick="goMenu()">Back to Menu</button>
  </div>
</div>

